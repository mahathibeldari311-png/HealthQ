# Server configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration (SQLite by default, swap to PostgreSQL in production)
DATABASE_URL=sqlite:///./instance/healthq.db

# Security
JWT_SECRET_KEY=supersecretkeyreplaceinproduction1234567890!@#
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Key (Required for AI medical analysis and smart OCR)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Uploads Configuration
UPLOAD_DIR=./instance/uploads
CLOUDINARY_URL=
